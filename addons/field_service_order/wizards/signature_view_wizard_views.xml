<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 簽名檢視精靈表單視圖 -->
    <record id="view_signature_view_wizard_form" model="ir.ui.view">
        <field name="name">field.service.signature.view.wizard.form</field>
        <field name="model">field.service.signature.view.wizard</field>
        <field name="arch" type="xml">
            <form string="客戶簽名">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="order_name" readonly="1"/>
                        </h1>
                        <h2>客戶簽名記錄</h2>
                    </div>
                    
                    <group>
                        <group string="工單資訊">
                            <field name="partner_id" readonly="1"/>
                            <field name="contact_id" readonly="1"/>
                            <field name="equipment_id" readonly="1"/>
                            <field name="technician_id" readonly="1"/>
                        </group>
                        <group string="簽名資訊">
                            <field name="signed_by" readonly="1"/>
                            <field name="signed_date" readonly="1"/>
                            <field name="signature_filename" readonly="1"/>
                            <field name="signature_upload_date" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="簽名檔案">
                        <field name="customer_signature_file" 
                               widget="image" 
                               readonly="1"
                               options="{'size': [800, 600]}"
                               invisible="not customer_signature_file"/>
                        <div invisible="customer_signature_file" class="alert alert-info" role="alert">
                            <p>尚未上傳簽名檔案</p>
                        </div>
                    </group>
                </sheet>
                
                <footer>
                    <button name="action_view_order" 
                            string="返回工單" 
                            type="object" 
                            class="btn-primary"/>
                    <button name="action_close" 
                            string="關閉" 
                            type="object" 
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>