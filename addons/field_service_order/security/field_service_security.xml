<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 使用者群組定義 -->
    
    <!-- 基礎使用者群組 -->
    <record id="group_field_service_user" model="res.groups">
        <field name="name">現場服務使用者</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">可以檢視和建立服務工單，但只能存取自己的工單</field>
    </record>

    <!-- 技術人員群組 -->
    <record id="group_field_service_technician" model="res.groups">
        <field name="name">現場服務技術人員</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="comment">可以執行服務工單，管理檢查清單和零件更換</field>
    </record>

    <!-- 管理員群組 -->
    <record id="group_field_service_manager" model="res.groups">
        <field name="name">現場服務管理員</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('group_field_service_technician'))]"/>
        <field name="comment">可以管理所有服務工單，配置系統設定和檢視報表</field>
    </record>

    <!-- 唯讀群組 -->
    <record id="group_field_service_viewer" model="res.groups">
        <field name="name">現場服務唯讀</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">可以查看所有服務工單和相關資料，但無法進行任何修改操作</field>
    </record>

    <!-- 記錄規則 (Row-level Security) -->
    
    <!-- 服務工單記錄規則 - 所有員工基於階層關係的權限控制（排除唯讀群組） -->
    <record id="rule_field_service_order_employee" model="ir.rule">
        <field name="name">服務工單：員工階層權限</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_user')), (4, ref('group_field_service_technician')), (4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[
            '|', '|', '|',
                ('create_uid', '=', user.id),
                ('technician_id.user_id', '=', user.id),
                ('technician_id', 'in', user.employee_id.child_ids.ids),
                ('technician_id.parent_id', '=', user.employee_id.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 客戶處理單記錄規則 - 基於員工階層關係（排除唯讀群組） -->
    <record id="rule_customer_service_sheet_employee" model="ir.rule">
        <field name="name">客戶處理單：員工階層權限</field>
        <field name="model_id" ref="model_customer_service_sheet"/>
        <field name="groups" eval="[(4, ref('group_field_service_user')), (4, ref('group_field_service_technician')), (4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[
            '|', '|', '|',
                ('create_uid', '=', user.id),
                ('service_order_id.technician_id.user_id', '=', user.id),
                ('service_order_id.technician_id', 'in', user.employee_id.child_ids.ids),
                ('service_order_id.technician_id.parent_id', '=', user.employee_id.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    
    <!-- 服務工單記錄規則 - 一般使用者只能看到自己相關的工單（已停用，改用員工階層規則） -->
    <record id="rule_field_service_order_user" model="ir.rule">
        <field name="name">服務工單：一般使用者（已停用）</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            '|',
                ('technician_id.user_id', '=', user.id),
            '|',
                ('create_uid', '=', user.id),
                ('partner_id.user_ids', 'in', user.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
        <field name="active" eval="False"/>
    </record>

    <!-- 服務工單記錄規則 - 技術人員可以看到指派給自己的工單（已停用，改用員工階層規則） -->
    <record id="rule_field_service_order_technician" model="ir.rule">
        <field name="name">服務工單：技術人員（已停用）</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_technician'))]"/>
        <field name="domain_force">[
            '|',
                ('technician_id.user_id', '=', user.id),
                ('technician_id', '=', False)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="active" eval="False"/>
    </record>

    <!-- 服務工單記錄規則 - 管理員可以看到所有工單 -->
    <record id="rule_field_service_order_manager" model="ir.rule">
        <field name="name">服務工單：管理員</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- 服務工單記錄規則 - 唯讀可以看到所有工單但只能讀取 -->
    <record id="rule_field_service_order_viewer" model="ir.rule">
        <field name="name">服務工單：唯讀</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_viewer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 檢查清單記錄規則 - 基於員工階層關係（排除唯讀群組） -->
    <record id="rule_field_service_checklist_employee" model="ir.rule">
        <field name="name">檢查清單：員工階層權限</field>
        <field name="model_id" ref="model_field_service_checklist_line"/>
        <field name="groups" eval="[(4, ref('group_field_service_user')), (4, ref('group_field_service_technician')), (4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[
            '|', '|', '|',
                ('order_id.create_uid', '=', user.id),
                ('order_id.technician_id.user_id', '=', user.id),
                ('order_id.technician_id', 'in', user.employee_id.child_ids.ids),
                ('order_id.technician_id.parent_id', '=', user.employee_id.id)
        ]</field>
    </record>

    <!-- 檢查清單記錄規則 - 繼承工單的權限（已停用） -->
    <record id="rule_field_service_checklist_user" model="ir.rule">
        <field name="name">檢查清單：使用者（已停用）</field>
        <field name="model_id" ref="model_field_service_checklist_line"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            '|',
                ('order_id.technician_id.user_id', '=', user.id),
            '|',
                ('order_id.create_uid', '=', user.id),
                ('order_id.partner_id.user_ids', 'in', user.id)
        ]</field>
        <field name="active" eval="False"/>
    </record>

    <!-- 費用記錄規則 - 基於員工階層關係（排除唯讀群組） -->
    <record id="rule_field_service_expense_employee" model="ir.rule">
        <field name="name">費用記錄：員工階層權限</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_user')), (4, ref('group_field_service_technician')), (4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[
            '|', '|',
                ('order_id.technician_id.user_id', '=', user.id),
                ('order_id.technician_id', 'in', user.employee_id.child_ids.ids),
                ('order_id.technician_id.parent_id', '=', user.employee_id.id)
        ]</field>
    </record>

    <!-- 費用記錄規則 - 限制存取權限（已停用） -->
    <record id="rule_field_service_expense_user" model="ir.rule">
        <field name="name">費用記錄：使用者（已停用）</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            ('order_id.technician_id.user_id', '=', user.id)
        ]</field>
        <field name="active" eval="False"/>
    </record>

    <!-- 費用記錄規則 - 管理員可看到所有費用 -->
    <record id="rule_field_service_expense_manager" model="ir.rule">
        <field name="name">費用記錄：管理員</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- 費用記錄規則 - 唯讀可看到所有費用但只能讀取 -->
    <record id="rule_field_service_expense_viewer" model="ir.rule">
        <field name="name">費用記錄：唯讀</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_viewer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 客戶處理單記錄規則 - 唯讀可看到所有客戶處理單 -->
    <record id="rule_customer_service_sheet_viewer" model="ir.rule">
        <field name="name">客戶處理單：唯讀</field>
        <field name="model_id" ref="model_customer_service_sheet"/>
        <field name="groups" eval="[(4, ref('group_field_service_viewer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 檢查清單記錄規則 - 唯讀可看到所有檢查清單 -->
    <record id="rule_field_service_checklist_viewer" model="ir.rule">
        <field name="name">檢查清單：唯讀</field>
        <field name="model_id" ref="model_field_service_checklist_line"/>
        <field name="groups" eval="[(4, ref('group_field_service_viewer'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
