<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 使用者群組定義 -->
    
    <!-- 基礎使用者群組 -->
    <record id="group_field_service_user" model="res.groups">
        <field name="name">現場服務使用者</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">可以檢視和建立服務工單，但只能存取自己的工單</field>
    </record>

    <!-- 技術人員群組 -->
    <record id="group_field_service_technician" model="res.groups">
        <field name="name">現場服務技術人員</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="comment">可以執行服務工單，管理檢查清單和零件更換</field>
    </record>

    <!-- 管理員群組 -->
    <record id="group_field_service_manager" model="res.groups">
        <field name="name">現場服務管理員</field>
        <field name="category_id" ref="base.module_category_services_field_service"/>
        <field name="implied_ids" eval="[(4, ref('group_field_service_technician'))]"/>
        <field name="comment">可以管理所有服務工單，配置系統設定和檢視報表</field>
    </record>

    <!-- 記錄規則 (Row-level Security) -->
    
    <!-- 服務工單記錄規則 - 一般使用者只能看到自己相關的工單 -->
    <record id="rule_field_service_order_user" model="ir.rule">
        <field name="name">服務工單：一般使用者</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            '|',
                ('technician_id.user_id', '=', user.id),
            '|',
                ('create_uid', '=', user.id),
                ('partner_id.user_ids', 'in', user.id)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 服務工單記錄規則 - 技術人員可以看到指派給自己的工單 -->
    <record id="rule_field_service_order_technician" model="ir.rule">
        <field name="name">服務工單：技術人員</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_technician'))]"/>
        <field name="domain_force">[
            '|',
                ('technician_id.user_id', '=', user.id),
                ('technician_id', '=', False)
        ]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- 服務工單記錄規則 - 管理員可以看到所有工單 -->
    <record id="rule_field_service_order_manager" model="ir.rule">
        <field name="name">服務工單：管理員</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="groups" eval="[(4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- 檢查清單記錄規則 - 繼承工單的權限 -->
    <record id="rule_field_service_checklist_user" model="ir.rule">
        <field name="name">檢查清單：使用者</field>
        <field name="model_id" ref="model_field_service_checklist_line"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            '|',
                ('order_id.technician_id.user_id', '=', user.id),
            '|',
                ('order_id.create_uid', '=', user.id),
                ('order_id.partner_id.user_ids', 'in', user.id)
        ]</field>
    </record>

    <!-- 費用記錄規則 - 限制存取權限 -->
    <record id="rule_field_service_expense_user" model="ir.rule">
        <field name="name">費用記錄：使用者</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            ('order_id.technician_id.user_id', '=', user.id)
        ]</field>
    </record>

    <!-- 費用記錄規則 - 管理員可看到所有費用 -->
    <record id="rule_field_service_expense_manager" model="ir.rule">
        <field name="name">費用記錄：管理員</field>
        <field name="model_id" ref="model_field_service_expense"/>
        <field name="groups" eval="[(4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- 零件更換記錄規則 -->
    <record id="rule_field_service_part_user" model="ir.rule">
        <field name="name">零件更換：使用者</field>
        <field name="model_id" ref="model_field_service_part_replacement"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[
            ('order_id.technician_id.user_id', '=', user.id)
        ]</field>
    </record>

    <!-- 標籤 - 所有使用者都可以看到 -->
    <record id="rule_field_service_tag_all" model="ir.rule">
        <field name="name">服務標籤：所有使用者</field>
        <field name="model_id" ref="model_field_service_tag"/>
        <field name="groups" eval="[(4, ref('group_field_service_user'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- 標籤 - 管理員可以管理 -->
    <record id="rule_field_service_tag_manager" model="ir.rule">
        <field name="name">服務標籤：管理員</field>
        <field name="model_id" ref="model_field_service_tag"/>
        <field name="groups" eval="[(4, ref('group_field_service_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>


    <!-- 多公司規則 -->
    <record id="rule_field_service_order_company" model="ir.rule">
        <field name="name">服務工單：多公司規則</field>
        <field name="model_id" ref="model_field_service_order"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

</odoo>