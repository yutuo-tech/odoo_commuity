<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 主選單 -->
    <menuitem id="menu_epm_root" 
              name="企業產品管理" 
              sequence="10"/>

    <!-- 產品管理子選單 -->
    <menuitem id="menu_epm_products" 
              name="產品管理" 
              parent="menu_epm_root" 
              sequence="10"/>

    <menuitem id="menu_epm_product_templates" 
              name="產品主檔" 
              parent="menu_epm_products" 
              action="product.product_template_action_all"
              sequence="10"/>

    <menuitem id="menu_epm_product_variants" 
              name="產品變體" 
              parent="menu_epm_products" 
              action="product.product_normal_action_sell"
