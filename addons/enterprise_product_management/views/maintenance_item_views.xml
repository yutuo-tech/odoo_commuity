<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 保養項目列表視圖 -->
    <record id="view_maintenance_item_tree" model="ir.ui.view">
        <field name="name">保養項目列表</field>
        <field name="model">epm.maintenance.item</field>
        <field name="arch" type="xml">
            <list string="保養項目">
                <field name="product_tmpl_id" string="產品"/>
                <field name="name" string="保養項目"/>
                <field name="maintenance_type" string="保養類型"/>
                <field name="price" string="定價"/>
                <field name="currency" string="幣值"/>
                <field name="is_public" string="外部顯示"/>
                <field name="sequence" string="順序"/>
                <field name="active" string="啟用"/>
                <field name="usage_count" string="使用次數"/>
            </list>
        </field>
    </record>

    <!-- 保養項目表單視圖 -->
    <record id="view_maintenance_item_form" model="ir.ui.view">
        <field name="name">保養項目表單</field>
        <field name="model">epm.maintenance.item</field>
        <field name="arch" type="xml">
            <form string="保養項目">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="increment_usage_count" type="object" 
                                class="oe_stat_button" icon="fa-plus">
                            <field name="usage_count" widget="statinfo" 
                                   string="使用次數"/>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="停用" bg_color="bg-danger" 
                            invisible="active"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="保養項目名稱..."/></h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="product_tmpl_id" 
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="maintenance_type"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="price"/>
                            <field name="currency" required="price > 0"/>
                            <field name="is_public"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="保養要點" name="key_points">
                            <field name="key_points" placeholder="請輸入保養的關鍵要點和注意事項..."/>
                        </page>
                        <page string="詳細描述" name="description">
                            <field name="description" placeholder="請輸入保養項目的詳細說明、步驟和要求..."/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter 隱藏不需要的功能
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
                -->
            </form>
        </field>
    </record>

    <!-- 保養項目搜尋視圖 -->
    <record id="view_maintenance_item_search" model="ir.ui.view">
        <field name="name">保養項目搜尋</field>
        <field name="model">epm.maintenance.item</field>
        <field name="arch" type="xml">
            <search string="保養項目搜尋">
                <field name="name" string="項目名稱" 
                       filter_domain="[('name','ilike',self)]"/>
                <field name="product_tmpl_id" string="產品"/>
                <field name="maintenance_type"/>
                <field name="key_points" string="保養要點"/>
                <field name="description" string="描述"/>
                
                <separator/>
                <filter name="filter_public" string="外部顯示" 
                        domain="[('is_public','=',True)]"/>
                <filter name="filter_private" string="僅內部" 
                        domain="[('is_public','=',False)]"/>
                
                <separator/>
                <filter name="filter_routine" string="例行保養" 
                        domain="[('maintenance_type','=','routine')]"/>
                <filter name="filter_major" string="大保養" 
                        domain="[('maintenance_type','=','major')]"/>
                <filter name="filter_quarterly" string="季度保養" 
                        domain="[('maintenance_type','=','quarterly')]"/>
                <filter name="filter_annual" string="年度保養" 
                        domain="[('maintenance_type','=','annual')]"/>
                
                <separator/>
                <filter name="filter_active" string="啟用" 
                        domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="停用" 
                        domain="[('active','=',False)]"/>
                
                <group expand="0" string="群組">
                    <filter string="產品" name="group_product" 
                            context="{'group_by':'product_tmpl_id'}"/>
                    <filter string="保養類型" name="group_maintenance_type" 
                            context="{'group_by':'maintenance_type'}"/>
                    <filter string="幣值" name="group_currency" 
                            context="{'group_by':'currency'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- 保養項目看板視圖 -->
    <record id="view_maintenance_item_kanban" model="ir.ui.view">
        <field name="name">保養項目看板</field>
        <field name="model">epm.maintenance.item</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="id"/>
                <field name="name"/>
                <field name="product_tmpl_id"/>
                <field name="maintenance_type"/>
                <field name="price"/>
                <field name="currency"/>
                <field name="is_public"/>
                <field name="active"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('product.template', 'image_128', record.product_tmpl_id.raw_value)" 
                                     t-att-title="record.product_tmpl_id.value" 
                                     t-att-alt="record.product_tmpl_id.value" 
                                     width="64" height="64"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="product_tmpl_id"/>
                                </div>
                                <div class="o_kanban_tags_section">
                                    <span t-if="record.price.raw_value" class="badge badge-pill badge-info">
                                        <field name="price"/> <field name="currency"/>
                                    </span>
                                    <span t-if="record.is_public.raw_value" class="badge badge-pill badge-success">
                                        外部可見
                                    </span>
                                    <span t-if="!record.active.raw_value" class="badge badge-pill badge-secondary">
                                        停用
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- 保養項目動作 -->
    <record id="action_maintenance_item" model="ir.actions.act_window">
        <field name="name">保養項目</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">epm.maintenance.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_maintenance_item_search"/>
        <field name="context">{
            'search_default_filter_active': 1,
            'search_default_group_product': 1
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                建立第一個保養項目
            </p>
            <p>
                保養項目用於定義產品的保養清單，可作為工單系統的 checklist 使用。<br/>
                您可以為每個產品定義不同類型的保養項目，並設定是否顯示給外部工單。
            </p>
        </field>
    </record>

    <!-- 快捷動作：依產品分組 -->
    <record id="action_maintenance_item_by_product" model="ir.actions.act_window">
        <field name="name">保養項目（依產品）</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">epm.maintenance.item</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_maintenance_item_search"/>
        <field name="context">{
            'search_default_filter_active': 1,
            'search_default_group_product': 1
        }</field>
    </record>

    <!-- 快捷動作：僅外部顯示項目 -->
    <record id="action_maintenance_item_public" model="ir.actions.act_window">
        <field name="name">外部保養項目</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">epm.maintenance.item</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_maintenance_item_search"/>
        <field name="context">{
            'search_default_filter_active': 1,
            'search_default_filter_public': 1,
            'search_default_group_maintenance_type': 1
        }</field>
    </record>
</odoo>