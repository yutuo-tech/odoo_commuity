<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 繼承產品模板表單視圖 -->
    <record id="view_product_template_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- 加入產品類型欄位 -->
            <xpath expr="//field[@name='type']" position="after">
                <field name="x_product_type"/>
            </xpath>
            
            <!-- 加入保養項目統計按鈕 -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_maintenance_items" type="object" 
                        class="oe_stat_button" icon="fa-wrench">
                    <field name="maintenance_item_count" widget="statinfo" 
                           string="保養項目"/>
                </button>
            </xpath>
            
            <!-- 在 notebook 中加入保養項目頁籤 -->
            <xpath expr="//notebook" position="inside">
                <page string="保養項目" name="maintenance_items">
                    <field name="maintenance_item_ids" context="{'default_product_tmpl_id': id}"/>
                </page>
            </xpath>
        </field>
    </record>

    <!-- 繼承產品模板列表視圖 -->
    <record id="view_product_template_tree_inherit" model="ir.ui.view">
        <field name="name">product.template.tree.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='list_price']" position="before">
                <field name="x_product_type"/>
            </xpath>
        </field>
    </record>

    <!-- 繼承產品模板搜尋視圖 -->
    <record id="view_product_template_search_inherit" model="ir.ui.view">
        <field name="name">product.template.search.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="x_product_type"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter string="產品類型" name="group_by_product_type" 
                        domain="[]" context="{'group_by': 'x_product_type'}"/>
            </xpath>
        </field>
    </record>
</odoo>