<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- 企業聯絡人管理權限分類 -->
        <record id="category_contact_management" model="ir.module.category">
            <field name="name">企業聯絡人管理</field>
            <field name="description">企業聯絡人管理權限設定</field>
            <field name="sequence">10</field>
        </record>

        <!-- 唯讀群組 (顯示在下拉選單) -->
        <record id="group_contact_readonly" model="res.groups">
            <field name="name">唯讀</field>
            <field name="category_id" ref="category_contact_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">可查看所有聯絡人資料，完全唯讀權限</field>
        </record>

        <!-- 使用者群組 (顯示在下拉選單) -->
        <record id="group_contact_user" model="res.groups">
            <field name="name">使用者</field>
            <field name="category_id" ref="category_contact_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">可進行聯絡人的一般操作</field>
        </record>

        <!-- 管理員群組 (顯示在下拉選單) -->
        <record id="group_contact_manager" model="res.groups">
            <field name="name">管理員</field>
            <field name="category_id" ref="category_contact_management"/>
            <field name="implied_ids" eval="[(4, ref('group_contact_user'))]"/>
            <field name="comment">可完整管理所有聯絡人資料</field>
        </record>

        <!-- 記錄規則 -->
        
        <!-- 公司部門存取規則 -->
        <record id="rule_company_department_readonly" model="ir.rule">
            <field name="name">公司部門：唯讀</field>
            <field name="model_id" ref="model_company_department"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_readonly'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_company_department_user" model="ir.rule">
            <field name="name">公司部門：使用者可編輯</field>
            <field name="model_id" ref="model_company_department"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_company_department_manager" model="ir.rule">
            <field name="name">公司部門：管理員完全存取</field>
            <field name="model_id" ref="model_company_department"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- 聯絡人存取規則 -->
        <record id="rule_company_contact_readonly" model="ir.rule">
            <field name="name">聯絡人：唯讀</field>
            <field name="model_id" ref="model_company_contact"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_readonly'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_company_contact_user" model="ir.rule">
            <field name="name">聯絡人：使用者可編輯</field>
            <field name="model_id" ref="model_company_contact"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_company_contact_manager" model="ir.rule">
            <field name="name">聯絡人：管理員完全存取</field>
            <field name="model_id" ref="model_company_contact"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4,ref('group_contact_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>