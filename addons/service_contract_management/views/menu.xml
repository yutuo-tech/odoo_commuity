<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 主選單 -->
    <menuitem id="menu_service_contract_management" 
              name="客戶設備合約管理"
              sequence="50"
              web_icon="service_contract_management,static/description/icon.png"/>

    <!-- 設備管理子選單 -->
    <menuitem id="menu_service_equipment_root" 
              name="設備管理" 
              parent="menu_service_contract_management"
              sequence="10"/>

    <menuitem id="menu_service_equipment_all" 
              name="所有設備"
              action="action_service_equipment"
              parent="menu_service_equipment_root"
              sequence="10"/>

    <menuitem id="menu_service_equipment_stock" 
              name="庫存設備"
              action="action_service_equipment_stock"
              parent="menu_service_equipment_root"
              sequence="20"/>

    <menuitem id="menu_service_equipment_customer" 
              name="客戶設備"
              action="action_service_equipment_customer"
              parent="menu_service_equipment_root"
              sequence="30"/>

    <menuitem id="menu_service_equipment_warranty_expiring" 
              name="保固即將到期"
              action="action_service_equipment_warranty_expiring"
              parent="menu_service_equipment_root"
              sequence="40"/>

    <!-- 合約管理子選單 -->
    <menuitem id="menu_service_contract_root" 
              name="合約管理" 
              parent="menu_service_contract_management"
              sequence="20"/>

    <menuitem id="menu_service_contract_all" 
              name="所有合約"
              action="action_service_contract"
              parent="menu_service_contract_root"
              sequence="10"/>

    <menuitem id="menu_service_contract_active" 
              name="有效合約"
              action="action_service_contract_active"
              parent="menu_service_contract_root"
              sequence="20"/>

    <menuitem id="menu_service_contract_expiring" 
              name="即將到期合約"
              action="action_service_contract_expiring"
              parent="menu_service_contract_root"
              sequence="30"/>

    <!-- 設定子選單 -->
    <menuitem id="menu_service_settings_root" 
              name="設定" 
              parent="menu_service_contract_management"
              sequence="30"
              groups="service_contract_management.group_service_admin"/>

    <menuitem id="menu_maintenance_checklist" 
              name="保養檢查項目"
              action="action_maintenance_checklist"
              parent="menu_service_settings_root"
              sequence="10"
              groups="service_contract_management.group_service_admin"/>

    <menuitem id="menu_maintenance_checklist_routine" 
              name="例行保養項目"
              action="action_maintenance_checklist_routine"
              parent="menu_service_settings_root"
              sequence="20"
              groups="service_contract_management.group_service_admin"/>

    <menuitem id="menu_maintenance_checklist_required" 
              name="必要檢查項目"
              action="action_maintenance_checklist_required"
              parent="menu_service_settings_root"
              sequence="30"
              groups="service_contract_management.group_service_admin"/>

</odoo>